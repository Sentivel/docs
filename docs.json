{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sentivel",
  "colors": {
    "primary": "#0a0a0a",
    "light": "#fafafa",
    "dark": "#0a0a0a"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#000000"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Geist",
    "heading": {
      "family": "Geist",
      "weight": 500
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart", "set-up-with-ai"]
          },
          {
            "group": "Monitoring & status",
            "pages": [
              "guides/monitors",
              "guides/status-pages",
              "guides/dependencies"
            ]
          },
          {
            "group": "Incidents & on-call",
            "pages": [
              "guides/incidents",
              "guides/escalation",
              "guides/integrations"
            ]
          },
          {
            "group": "Your workspace",
            "pages": ["guides/account"]
          },
          {
            "group": "Developers",
            "pages": ["authentication", "api-overview"]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "code",
        "openapi": "https://www.sentivel.com/api/v1/openapi.json",
        "groups": [
          {
            "group": "Account",
            "pages": ["GET /me"]
          },
          {
            "group": "Components",
            "pages": [
              "GET /components",
              "POST /components",
              "PATCH /components/{id}",
              "DELETE /components/{id}"
            ]
          },
          {
            "group": "Monitors",
            "pages": [
              "GET /monitors",
              "POST /monitors",
              "PATCH /monitors/{id}",
              "DELETE /monitors/{id}",
              "GET /monitors/{id}/uptime"
            ]
          },
          {
            "group": "Status pages",
            "pages": [
              "GET /status-pages",
              "POST /status-pages",
              "PATCH /status-pages/{id}",
              "DELETE /status-pages/{id}"
            ]
          },
          {
            "group": "Incidents",
            "pages": ["GET /incidents", "POST /incidents", "GET /incidents/{id}"]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sentivel.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://www.sentivel.com/dashboard"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "website": "https://www.sentivel.com",
      "github": "https://github.com/Sentivel"
    }
  }
}
